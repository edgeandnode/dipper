{
  "db_name": "PostgreSQL",
  "query": "UPDATE pgmq_queue\n            SET\n                updated_at = timezone('UTC', now()),\n                status = $1\n            WHERE id IN (\n                SELECT id\n                FROM pgmq_queue\n                WHERE status = $2 AND scheduled_for <= timezone('UTC', now())\n                ORDER BY scheduled_for\n                FOR UPDATE SKIP LOCKED\n                LIMIT 1\n            )\n            RETURNING *",
