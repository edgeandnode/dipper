{
  "db_name": "PostgreSQL",
  "query": "UPDATE pgmq_queue\n            SET status = $1, updated_at = $2\n            WHERE id IN (\n                SELECT id\n                FROM pgmq_queue\n                WHERE status = $3 AND scheduled_for <= $4 AND failed_attempts < $5\n                ORDER BY scheduled_for\n                FOR UPDATE SKIP LOCKED\n                LIMIT $6\n            )\n            RETURNING *",
